scale_y_continuous(breaks = NULL)+
stat_function(fun = dnorm,
geom = "area",
fill = "steelblue",
xlim = c(-0.71, 0.92), alpha=0.5) +
theme_bw()+
scale_x_continuous(breaks = c(-3,-0.71, 0, 0.92, 3),
labels = c(-3, -0.71,0, 0.92, 3),
limits = c(-3, 3))
