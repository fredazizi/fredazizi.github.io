(0.6)^5
# beta is defined as the scale parameter
beta<-runif(1,0,100)
# alpha_1 and alpha_2 are defined as the shape parameters.
alpha1<-runif(1,0,100)
alpha2<-runif(1,0,100)
# Taking samples form indep x1~Gamma(beta,alpha1)
# and x2~Gamma(beta,alpha2)
x1<-rgamma(10^6, shape=alpha1, scale = beta)
x2<-rgamma(10^6, shape=alpha2, scale = beta)
# define Y1=X1+X2, Y2=(X1)/(X1+X2)
y1<- x1+x2
y2<- x1/(x1+x2)
# claim: y1~Gamma(beta, alpha1+alpha2)
gamma<-rgamma(10^6, shape = alpha1+alpha2, scale = beta)
plot(density(x1+x2),main="Hello")
# beta is defined as the scale parameter
beta<-runif(1,0,100)
# alpha_1 and alpha_2 are defined as the shape parameters.
alpha1<-runif(1,0,100)
alpha2<-runif(1,0,100)
# Taking samples form indep x1~Gamma(beta,alpha1)
# and x2~Gamma(beta,alpha2)
x1<-rgamma(10^6, shape=alpha1, scale = beta)
x2<-rgamma(10^6, shape=alpha2, scale = beta)
# define Y1=X1+X2, Y2=(X1)/(X1+X2)
y1<- x1+x2
y2<- x1/(x1+x2)
# claim: y1~Gamma(beta, alpha1+alpha2)
gamma<-rgamma(10^6, shape = alpha1+alpha2, scale = beta)
plot(density(x1+x2), main="comparing dist of y1 with gamma(beta, alpha1+alpha2)")
lines(density(gamma))
lines(density(gamma), col="red")
plot(density(x1+x2), main="comparing dist of y1 with gamma(beta, alpha1+alpha2)")
lines(density(gamma), col="red")
